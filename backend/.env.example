APP_NAME=SyndikPro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_MA

FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=syndikpro
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@syndikpro.ma"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp (Twilio BSP)
TWILIO_SID=
TWILIO_TOKEN=
# Sans préfixe "whatsapp:" — le provider le préfixe. Ex: +212704768521
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# WhatsApp templates approuvés par Meta (Content SID "HX..." — diffèrent par env)
WA_TPL_APPEL_FONDS=
WA_TPL_RAPPEL_PAIEMENT=
WA_TPL_RECU_PAIEMENT=
WA_TPL_WELCOME_COPRO=

# SMS8.io (SMS Maroc — Phase 1 primary)
SMS8_API_KEY=
SMS8_DEVICE_ID=

# Resend (email — 3000/mois free tier)
# From-address per tenant: {tenant.subdomain}@{RESEND_DOMAIN} (ex: blanca@imaro.ma)
RESEND_API_KEY=
RESEND_DOMAIN=imaro.ma
RESEND_FALLBACK_FROM=no-reply@imaro.ma

# Brevo email (legacy, à retirer une fois Resend en place)
BREVO_API_KEY=

# Sentry (à remplir en staging)
SENTRY_LARAVEL_DSN=

# Multi-tenant
TENANCY_SUBDOMAIN_COLUMN=subdomain
