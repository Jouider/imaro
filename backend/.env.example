APP_NAME=SyndikPro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_MA

FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=syndikpro
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@syndikpro.ma"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp (Twilio BSP)
TWILIO_SID=
TWILIO_TOKEN=
# Sans préfixe "whatsapp:" — le provider le préfixe. Ex: +212704768521
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# WhatsApp templates approuvés par Meta (Content SID "HX..." — diffèrent par env)
WA_TPL_APPEL_FONDS=
WA_TPL_RAPPEL_PAIEMENT=
WA_TPL_RECU_PAIEMENT=
WA_TPL_WELCOME_COPRO=
# Template AUTHENTICATION (code d'accès copro) — cascade onboarding SMS→WA→Email
WA_TPL_ACCES_COPRO=

# SMS8.io (SMS Maroc — Phase 1 primary)
SMS8_API_KEY=
SMS8_DEVICE_ID=

# Resend (email — 3000/mois free tier)
# From-address per tenant: {tenant.subdomain}@{RESEND_DOMAIN} (ex: blanca@imaro.ma)
RESEND_API_KEY=
RESEND_DOMAIN=imaro.ma
RESEND_FALLBACK_FROM=no-reply@imaro.ma

# Boîte IT recevant les demandes d'assistance recouvrement (#179)
ASSISTANCE_RECOUVREMENT_EMAIL=recouvrement@imaro.ma

# Deep-links app native (KAN-71) — renseigner depuis le build natif (Mouad)
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=ma.imaro.portail
ANDROID_PACKAGE=ma.imaro.portail
# Empreintes SHA-256 du certificat de signature Android (séparées par des virgules)
ANDROID_SHA256_FINGERPRINTS=

# Push natif mobile (KAN-68) — laisser vide tant que l'app native n'est pas en prod
# Android — Firebase Cloud Messaging HTTP v1 (JSON du compte de service)
FCM_PROJECT_ID=
FCM_CREDENTIALS=
# iOS — Apple Push Notification service (clé .p8)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=ma.imaro.app
APNS_KEY_PATH=
APNS_PRODUCTION=false

# Brevo email (legacy, à retirer une fois Resend en place)
BREVO_API_KEY=

# Sentry (à remplir en staging)
SENTRY_LARAVEL_DSN=

# Conformité CNDP (loi 09-08) — version de la politique de confidentialité (KAN-60)
CNDP_POLICY_VERSION=1.0

# Multi-tenant
TENANCY_SUBDOMAIN_COLUMN=subdomain
