{
  "info": {
    "name": "SyndikPro — Backend API",
    "description": "Collection complète pour tester le backend SyndikPro.\n\n**Workflow de test :**\n1. Exécuter «01 - Demander OTP» (manager ou gestionnaire)\n2. Récupérer l'OTP dans les logs : `grep \"OTP SIMULÉ\" backend/storage/logs/laravel.log | tail -1`\n3. Exécuter «02 - Vérifier OTP» → le token est sauvegardé automatiquement\n4. Tester les endpoints dans l'ordre des dossiers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{gestionnaire_token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "manager_token", "value": "", "type": "string" },
    { "key": "gestionnaire_token", "value": "", "type": "string" },
    { "key": "residence_id", "value": "1", "type": "string" },
    { "key": "lot_id", "value": "1", "type": "string" },
    { "key": "appel_fonds_id", "value": "1", "type": "string" },
    { "key": "appel_fonds_ligne_id", "value": "1", "type": "string" },
    { "key": "ticket_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Authentification OTP sans mot de passe. Après verify-otp, le token est sauvegardé automatiquement dans les variables de la collection.",
      "item": [
        {
          "name": "01 - Demander OTP (Manager)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status success', () => pm.expect(pm.response.json().status).to.eql('success'));",
                  "console.log('⚠️  Récupérer OTP: grep \"OTP SIMULÉ\" backend/storage/logs/laravel.log | tail -1');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+212600000001\"\n}"
            },
            "url": "{{base_url}}/api/auth/request-otp",
            "description": "Demande un OTP pour le manager Mohammed Fikri (+212600000001).\nL'OTP apparaît dans les logs Laravel."
          }
        },
        {
          "name": "01 - Demander OTP (Gestionnaire)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "console.log('⚠️  Récupérer OTP: grep \"OTP SIMULÉ\" backend/storage/logs/laravel.log | tail -1');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+212600000002\"\n}"
            },
            "url": "{{base_url}}/api/auth/request-otp",
            "description": "Demande un OTP pour Karim Alaoui (gestionnaire, +212600000002)."
          }
        },
        {
          "name": "02 - Vérifier OTP → Token Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('manager_token', json.data.token);",
                  "  console.log('✅ manager_token sauvegardé:', json.data.token.substring(0, 20) + '...');",
                  "  console.log('👤 Connecté en tant que:', json.data.user.name, '|', json.data.user.role);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+212600000001\",\n  \"otp\": \"REMPLACER_PAR_OTP\"\n}"
            },
            "url": "{{base_url}}/api/auth/verify-otp",
            "description": "Remplace REMPLACER_PAR_OTP par le code des logs.\nLe token manager est sauvegardé automatiquement."
          }
        },
        {
          "name": "02 - Vérifier OTP → Token Gestionnaire",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('gestionnaire_token', json.data.token);",
                  "  console.log('✅ gestionnaire_token sauvegardé:', json.data.token.substring(0, 20) + '...');",
                  "  console.log('👤 Connecté en tant que:', json.data.user.name, '|', json.data.user.role);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+212600000002\",\n  \"otp\": \"REMPLACER_PAR_OTP\"\n}"
            },
            "url": "{{base_url}}/api/auth/verify-otp",
            "description": "Remplace REMPLACER_PAR_OTP par le code des logs.\nLe token gestionnaire est sauvegardé automatiquement."
          }
        },
        {
          "name": "03 - Mon profil (/auth/me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => pm.expect(pm.response.json().data.user).to.exist);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "description": "Retourne le profil de l'utilisateur connecté avec ses rôles et permissions."
          }
        },
        {
          "name": "04 - Déconnexion",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('gestionnaire_token', '');",
                  "console.log('✅ Token révoqué');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/logout",
            "description": "Révoque le token Sanctum courant."
          }
        },
        {
          "name": "❌ OTP invalide (test 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('Format téléphone invalide', () => pm.expect(pm.response.json().status).to.eql('error'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0612345678\"\n}"
            },
            "url": "{{base_url}}/api/auth/request-otp",
            "description": "Doit retourner 422 — format téléphone non +212."
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "description": "KPIs gestionnaire — mis en cache Redis 5 minutes.",
      "item": [
        {
          "name": "Dashboard KPIs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.test('Has all KPIs', () => {",
                  "  pm.expect(data.residences_count).to.exist;",
                  "  pm.expect(data.lots_count).to.exist;",
                  "  pm.expect(data.taux_recouvrement).to.exist;",
                  "  pm.expect(data.tickets_ouverts).to.exist;",
                  "});",
                  "console.log('📊 KPIs:', JSON.stringify(data, null, 2));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/gestionnaire/dashboard",
            "description": "Retourne les KPIs des résidences assignées au gestionnaire connecté."
          }
        }
      ]
    },
    {
      "name": "🏢 Résidences",
      "description": "Gestion des résidences assignées au gestionnaire.",
      "item": [
