    {
      "name": "🏠 Lots & Tantièmes",
      "description": "Gestion des lots. Règle métier: somme tantièmes ≤ total_tantieme (1000).",
      "item": [
        {
          "name": "Liste des lots",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "console.log('🏠 Lots:', data.lots.length, '| Sum tantièmes:', data.sum_tantieme, '/ Total:', data.total_tantieme);",
                  "if (data.lots.length > 0) {",
                  "  pm.collectionVariables.set('lot_id', data.lots[0].id.toString());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/gestionnaire/residences/{{residence_id}}/lots",
            "description": "Retourne les lots avec la somme des tantièmes."
          }
        },
        {
          "name": "Créer un lot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 ou 422', () => {",
                  "  pm.expect([201, 422]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 422) {",
                  "  console.log('⚠️  Budget tantième dépassé:', pm.response.json().message);",
                  "} else {",
                  "  const lot = pm.response.json().data.lot;",
                  "  pm.collectionVariables.set('lot_id', lot.id.toString());",
                  "  console.log('✅ Lot créé ID:', lot.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
