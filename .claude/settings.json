{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)",
      "Bash(npm run format:check:*)",
      "Bash(npm run storybook:*)",
      "Bash(npm run preview:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx vite:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-remote:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git rebase origin/develop:*)",
      "Bash(git checkout:*)",
      "Bash(git add frontend/:*)",
      "Bash(git add .claude/:*)",
      "Bash(git add docs/:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(find . -name *.ts:*)",
      "Bash(find . -name *.tsx:*)",
      "Bash(find . -name *.json:*)",
      "Bash(curl -s http://localhost:5173/*)",
      "Bash(curl -s -o /dev/null http://localhost:5173/*)",
      "Bash(curl -sI http://localhost:5173/*)",
      "Bash(curl -s http://localhost:6006/*)",
      "Bash(curl -s -o /dev/null http://localhost:6006/*)",
      "Bash(curl -s http://localhost:8000/api/*)",
      "Bash(node -v:*)",
      "Bash(npm -v:*)",
      "Bash(pnpm -v:*)",
      "Bash(which:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D main:*)",
      "Bash(git branch -D develop:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
