# Signature release Android (KAN-74) — COPIER vers keystore.properties et remplir.
# keystore.properties est gitignoré : ne JAMAIS committer la clé ni les mots de passe.
#
# 1. Générer la clé d'upload (une seule fois) :
#    keytool -genkey -v -keystore imaro-upload.jks -keyalg RSA -keysize 2048 \
#            -validity 10000 -alias imaro-upload
#
# 2. Renseigner les valeurs ci-dessous (chemin relatif au dossier android/).
#
# 3. Récupérer le SHA-256 (à transmettre à Abdellah pour assetlinks.json, KAN-70/71) :
#    keytool -list -v -keystore imaro-upload.jks -alias imaro-upload
#
# 4. Build de l'AAB signé :
#    ./gradlew bundleRelease   →  app/build/outputs/bundle/release/app-release.aab

storeFile=imaro-upload.jks
storePassword=CHANGE_ME
keyAlias=imaro-upload
keyPassword=CHANGE_ME
