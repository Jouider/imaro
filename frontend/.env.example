# Base URL de l'API backend. EN PRODUCTION : pointer vers l'API réelle
# (ex. https://api.imaro.ma/api). Le défaut localhost ne vaut que pour le dev.
VITE_API_URL=http://localhost:8000/api

# Nom de l'app (titre, libellés).
VITE_APP_NAME=Imaro

# Clé publique VAPID pour le Web Push (PWA navigateur). L'app native iOS/Android
# utilise FCM/APNs et n'en a pas besoin. Laisser vide si le web push n'est pas activé.
VITE_PUSH_VAPID_PUBLIC_KEY=

# ⚠️ DEV UNIQUEMENT — expose le bypass de login + le fallback mock (données
# fictives quand l'API échoue). NE JAMAIS définir en production : laisser la
# variable totalement ABSENTE (même `VITE_SHOW_DEV_BYPASS=false` l'ACTIVE, car
# toute valeur non vide est « truthy »).
# VITE_SHOW_DEV_BYPASS=1
